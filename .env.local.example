# ============================================================
# ENVIROWORX CLOUD - Environment Variables
# Copy this to .env.local and fill in your Supabase details
# ============================================================

# Supabase (from supabase.com > Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# Twilio SMS (optional - for driver notifications)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-token-here
TWILIO_FROM_NUMBER=+44xxxxxxxxxx

# API security (required in production)
# Vercel crons send Authorization: Bearer <CRON_SECRET> when set
CRON_SECRET=generate-a-long-random-string
ADMIN_API_SECRET=optional-separate-secret-for-scripts
SESSION_SECRET=another-long-random-string-for-jwt-sessions

# Office: Google sign-in (Supabase Auth → Authentication → Providers → Google)
# In Supabase: set Site URL + Redirect URLs to include https://YOUR_DOMAIN/auth/callback
# Restrict who can access /office after Google OAuth (production requires at least one list):
OFFICE_GOOGLE_ALLOWED_DOMAINS=yourcompany.co.uk,example.com
# OFFICE_GOOGLE_ALLOWED_EMAILS=person@other-domain.com
# Optional: allow driver/yard PIN login alongside Google (default: Google only)
# OFFICE_PIN_AUTH_ENABLED=true

# Optional: public app URL for links in emails/SMS
# NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# Uptime monitor: GET /api/health

# Optional: Slack/Discord webhook for server errors (see src/lib/monitoring.ts)
# MONITORING_WEBHOOK_URL=https://hooks.slack.com/services/...

# Google Maps API — enable Places API + Geocoding API in Google Cloud Console
# Server-side key (used by address autocomplete server actions; keep it server-only).
GOOGLE_MAPS_API_KEY=your-key-here
# Browser key for the office Skip Map (Google Maps JavaScript API).
# MUST be a SEPARATE key restricted by HTTP referrer to your domain(s).
# Enable "Maps JavaScript API" on it in Google Cloud Console.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-browser-restricted-key-here
