# ============================================================
# ENVIROWORX CLOUD - Environment Variables
# Copy this to .env.local and fill in your credentials
# ============================================================

# Supabase (from supabase.com > Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Stripe (from dashboard.stripe.com > API Keys)
STRIPE_SECRET_KEY=sk_live_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-secret-here

# Twilio SMS (optional - for driver notifications)
TWILIO_ACCOUNT_SID=your-sid-here
TWILIO_AUTH_TOKEN=your-token-here
TWILIO_FROM_NUMBER=+447700000000

# Google Maps API (optional - for address lookup)
GOOGLE_MAPS_API_KEY=your-key-here

# Google Drive / Sheets (optional - for SEPA logging)
GOOGLE_DRIVE_CREDENTIALS={"type":"service_account",...}
GOOGLE_DRIVE_SHEET_ID=your-spreadsheet-id

# Verizon / Fleetmatics (optional - for vehicle telematics)
VERIZON_APP_ID=your-app-id
VERIZON_API_KEY=your-api-key
