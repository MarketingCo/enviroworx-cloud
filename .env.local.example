# ============================================================
# ENVIROWORX CLOUD - Environment Variables
# Copy this to .env.local and fill in your Supabase details
# ============================================================

# Supabase (from supabase.com > Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# Twilio SMS (optional - for driver notifications)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-token-here
TWILIO_FROM_NUMBER=+44xxxxxxxxxx

# API security (required in production)
# Vercel crons send Authorization: Bearer <CRON_SECRET> when set
CRON_SECRET=generate-a-long-random-string
ADMIN_API_SECRET=optional-separate-secret-for-scripts
SESSION_SECRET=another-long-random-string-for-jwt-sessions

# Google Maps API — enable Places API + Geocoding API in Google Cloud Console
GOOGLE_MAPS_API_KEY=your-key-here
