# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Twilio (rotate Auth Token if the old one was committed)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+44XXXXXXXXXX

# QuickBooks
QB_CLIENT_ID=your-qb-client-id
QB_CLIENT_SECRET=your-qb-client-secret
QB_REDIRECT_URI=https://your-app.vercel.app/api/qb/callback
QB_SANDBOX=true

# Verizon Fleetmatics
VERIZON_CLIENT_ID=your-verizon-client-id
VERIZON_CLIENT_SECRET=your-verizon-client-secret

# Google APIs
GOOGLE_MAPS_API_KEY=your-google-maps-key
GOOGLE_SERVICE_ACCOUNT_KEY=your-service-account-json

# Cron authentication (generate with: openssl rand -hex 32)
CRON_SECRET=your-cron-secret-here

# Sentry (Phase 8 — install @sentry/nextjs to activate)
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
