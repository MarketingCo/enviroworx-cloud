# ============================================================
# ENVIROWORX CLOUD - Environment Variables
# Copy this to .env.local and fill in your Supabase details
# ============================================================

# Cron job protection -- set a long random secret (e.g. `openssl rand -base64 32`)
CRON_SECRET=your-cron-secret-here

# Supabase (from supabase.com > Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# Twilio SMS (optional - for driver notifications)
TWILIO_ACCOUNT_SID=ACc46a2cd2956812318d5d35eb2ba2596a
TWILIO_AUTH_TOKEN=your-token-here
TWILIO_FROM_NUMBER=+447700161941

# Google Maps API (optional - for address lookup)
GOOGLE_MAPS_API_KEY=your-key-here

# QuickBooks
QB_CLIENT_ID=your-qb-client-id
QB_CLIENT_SECRET=your-qb-client-secret
QB_REDIRECT_URI=https://your-app.vercel.app/api/qb/callback
QB_SANDBOX=true  # Set to false for production

# PWA (service worker)
# No env vars needed for PWA, but PIN_SECRET is used for driver PIN hashing
PIN_SECRET=change-this-to-a-random-string-in-production

# Sentry error tracking (Phase 8 — install @sentry/nextjs to activate)
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
