# ============================================================
# ENVIROWORX CLOUD - Environment Variables Template
# ============================================================

# --- SUPABASE (Required) ---
# From Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- STRIPE (Required for Online Payments) ---
# From Stripe Dashboard > Developers > API keys / Webhooks
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- TWILIO (Required for SMS Notifications) ---
# From Twilio Console
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your-token
TWILIO_FROM_NUMBER=+44...

# --- GOOGLE DRIVE (Required for Cash Logging) ---
# Service Account JSON (entire content as a string)
GOOGLE_DRIVE_CREDENTIALS={"type": "service_account", ...}
GOOGLE_DRIVE_SHEET_ID=your-spreadsheet-id

# --- QUICKBOOKS (Required for Finance Sync) ---
# Client ID/Secret from Intuit Developer Portal
QUICKBOOKS_CLIENT_ID=your-client-id
QUICKBOOKS_CLIENT_SECRET=your-client-secret
QUICKBOOKS_REDIRECT_URI=http://localhost:3000/api/auth/callback/quickbooks
QUICKBOOKS_ENVIRONMENT=sandbox

# --- GOOGLE MAPS (Required for Address Suggestions) ---
# API Key from Google Cloud Console
GOOGLE_MAPS_API_KEY=AIza...

# --- VERIZON (Required for GPS/Telemetry Sync) ---
# App ID and API Key from Verizon Connect / Fleetmatics API
VERIZON_APP_ID=your-app-id
VERIZON_API_KEY=your-api-key
